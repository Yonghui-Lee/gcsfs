# fio/jobs/smoke_test_sync_read_local.fio

[global]
ioengine=external:./libgcsfs_sync_fio_engine.so
bs=1M
size=100M
numjobs=1
filename=./tmp/fio_local_test_file

# Configure fsspec's standard read-ahead cache
cache_type=readahead
block_size=8388608 # 8MB read-ahead block size

[sync_read_local_job]
rw=read
